{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabled": true,
  "semanticCommitType": "deps",
  "packageRules": [
    {
      "matchPackagePatterns": ["@grapity/*"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "platformAutomerge": true
    }
  ]
}
